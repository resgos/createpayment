# Пример env-переменных для prod-профиля.
# Подкладывай через k8s ConfigMap/Secret или systemd EnvironmentFile.
# Активация: SPRING_PROFILES_ACTIVE=prod

# --- Обязательные ----------------------------------------------------
DATASPACE_URL=http://dataspace-prod.delta.sbrf.ru:8090
PGW_URL=https://ingress-pgw-4g.<prod-host>/
RESULT_CALLBACK_URL=https://<initiator-host>/callback/payment-result
SBER_INTEGRATION_URL=http://stmnt-http.<prod-host>/sberintegration-statement-server/execute

# --- Опциональные тюны таймаутов (мс) -------------------------------
DATASPACE_CONNECT_TIMEOUT_MS=5000
DATASPACE_READ_TIMEOUT_MS=30000

PGW_CONNECT_TIMEOUT_MS=5000
PGW_READ_TIMEOUT_MS=60000
PGW_MAX_ATTEMPTS=5
PGW_RETRY_DELAY_MS=30000

RESULT_CALLBACK_CONNECT_TIMEOUT_MS=5000
RESULT_CALLBACK_READ_TIMEOUT_MS=15000
RESULT_CALLBACK_MAX_ATTEMPTS=5
RESULT_CALLBACK_RETRY_DELAY_MS=10000

SBER_INTEGRATION_CONNECT_TIMEOUT_MS=5000
SBER_INTEGRATION_READ_TIMEOUT_MS=15000
SBER_INTEGRATION_BIC_DIRECTORY=true

# --- Прочее ----------------------------------------------------------
SERVER_PORT=8080
ACTUATOR_HEALTH_DETAILS=never
LOG_LEVEL_MODULEX=INFO
